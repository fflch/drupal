        "league/commonmark": "^2.8",
        "markbaker/matrix": "2.0.0",
        "mglaman/composer-drupal-lenient": "^1.0",
        "npm-asset/ckeditor_youtube": "2.1.15",
        "npm-asset/fakeobjects": "4.15.0",
        "npm-asset/jquery-ui-touch-punch": "0.2.3",
        "npm-asset/juicebox_lite": "1.5.1",
        "npm-asset/tabletoolstoolbar": "0.0.1",
        "oomphinc/composer-installers-extender": "^2.0",
        "uspdev/utils": "^1.0",
        "uspdev/webform_boleto_usp": "1.0.13"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "audit": {
            "block-insecure": false
        },
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "drupal/console-extend-plugin": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "oomphinc/composer-installers-extender": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "tbachert/spi": true,
            "mglaman/composer-drupal-lenient": true
        },
        "process-timeout": 0
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            }
        },
        "patches": {
            "drupal/editor_file": {
                "3057895 - Uploaded files are not permanent": "https://www.drupal.org/files/issues/2019-05-29/file-upload-marked-permanent-3057895-2.patch"
            },
            "drupal/tamper": {
                "Define um novo filtro de parser de data no tamper": "https://www.drupal.org/files/issues/2020-09-13/3018621-5.patch"
            },
            "drupal/youtube_playlist": {
                "Mudanças temporárias para uso na FFLCH": "patches/youtube_playlist/2e033f41.patch"
            },
            "drupal/panelbutton": {
                "3105283 - fix location": "patches/panelbutton/1.3.patch"
            },
            "drupal/colorbutton": {
                "3046766 - fix location": "patches/colorbutton/1.2.patch"
            },
            "drupal/anchor_link": {
                "fix location": "patches/anchor_link/2.4.patch"
            },
            "drupal/ckeditor_tableresize": {
                "fix location": "patches/ckeditor_tableresize/1.0.patch"
            },
            "drupal/ckeditor_resize": {
                "fix location": "patches/ckeditor_resize/1.3.patch"
            }
        },
        "installer-types": [
            "npm-asset",
            "bower-asset"
        ],
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/juicebox": [
                "npm-asset/juicebox_lite"
            ],
            "web/libraries/youtube": [
                "npm-asset/ckeditor_youtube"
            ],
            "web/libraries/ckeditor": [
                "bower-asset/ckeditor-dev"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library",
                "type:npm-asset",
                "type:bower-asset"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ],
            "web/modules/custom/{$name}": [
                "type:drupal-custom-module"
            ],
            "web/themes/custom/{$name}": [
                "type:drupal-custom-theme"
            ]
        },
        "drupal-lenient": {
            "allowed-list": ["drupal/boxout", "drupal/cache_control_override"]
        }
    },
    "require-dev": {
        "drupal/core-dev": "^10.0"
    }
}
